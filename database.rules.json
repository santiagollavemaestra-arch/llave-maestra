{
  "rules": {
    "agencias": {
      "$agenciaId": {
        ".read": "auth != null && (root.child('usuarios').child(auth.uid).child('agenciaId').val() === $agenciaId || root.child('usuarios').child(auth.uid).child('rol').val() === 'keynet-admin')",
        ".write": "auth != null && (root.child('usuarios').child(auth.uid).child('agenciaId').val() === $agenciaId || root.child('usuarios').child(auth.uid).child('rol').val() === 'keynet-admin')"
      }
    },
    "keynet": {
      ".write": false,
      "agencias": {
        ".read": "auth != null && root.child('usuarios').child(auth.uid).child('rol').val() === 'keynet-admin'",
        "$agenciaId": {
          ".read": "auth != null && (root.child('usuarios').child(auth.uid).child('rol').val() === 'keynet-admin' || root.child('usuarios').child(auth.uid).child('agenciaId').val() === $agenciaId)"
        }
      }
    },
    "usuarios": {
      "$uid": {
        ".read": "auth != null && (auth.uid === $uid || root.child('usuarios').child(auth.uid).child('rol').val() === 'keynet-admin')",
        ".write": "auth != null && (auth.uid === $uid || root.child('usuarios').child(auth.uid).child('rol').val() === 'keynet-admin')"
      }
    }
  }
}
